generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  passwordHash     String?
  googleId         String?           @unique
  createdAt        DateTime          @default(now())
  messages         Message[]
  refreshTokens    RefreshToken[]
  workspaceMembers WorkspaceMember[]
}

model Workspace {
  id                           String              @id @default(cuid())
  name                         String

  businessEmail                String?
  phone                        String?
  website                      String?
  address                      String?
  description                  String?
  logoUrl                      String?
  businessName                 String?
  language                     String?              @default("en")
  timezone                     String?              @default("Asia/Kolkata")
  dateFormat                   String?              @default("DD/MM/YYYY")
  timeFormat                   String?              @default("12h")
  currency                     String?              @default("INR")
  businessCategory             String?

  plan                         String              @default("FREE")
  webhookUrl                   String?
  webhookVerifyToken           String              @default("")
  notifyNewConversation        Boolean             @default(true)
  notifyTemplateApproved       Boolean             @default(true)
  notifyTemplateRejected       Boolean             @default(true)
  notifyCampaignCompleted      Boolean             @default(true)
  notifyHighOptout             Boolean             @default(true)
  notifyRateLimit              Boolean             @default(true)
  emailNotifyCampaignCompleted Boolean             @default(true)
  emailNotifyTemplateApproved  Boolean             @default(true)
  emailNotifyTemplateRejected  Boolean             @default(true)
  emailNotifyMemberInvite      Boolean             @default(true)
  autoOooEnabled               Boolean             @default(true)
  autoWelcomeEnabled           Boolean             @default(true)
  autoDelayedEnabled           Boolean             @default(false)
  voiceAiEnabled               Boolean             @default(false)
  voiceAiName                  String              @default("MyCallGenie")
  voiceAiPrompt                String              @default("Greet the caller and ask for their details.")
  voiceAiPhone                 String              @default("")
  createdAt                    DateTime            @default(now())

  members       WorkspaceMember[]
  waNumbers     WaNumber[]
  templates     Template[]
  contacts      Contact[]
  campaigns     Campaign[]
  conversations Conversation[]
  triggers      AutomationTrigger[]
  workflows     Workflow[]
  apiKeys       ApiKey[]
  invoices      Invoice[]
  segments      Segment[]
  whatsappForms WhatsappForm[]
}

model WorkspaceMember {
  userId      String
  workspaceId String
  role        Role      @default(CLIENT)
  joinedAt    DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([userId, workspaceId])
}

model WaNumber {
  id                   String         @id @default(cuid())
  workspaceId          String
  phoneNumber          String
  metaPhoneNumberId    String
  wabaId               String
  encryptedAccessToken String
  displayName          String?
  quality              String?
  status               String         @default("ACTIVE")
  messagingLimit       String?
  createdAt            DateTime       @default(now())
  campaigns            Campaign[]
  conversations        Conversation[]
  workspace            Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model NumberPool {
  id                   String           @id @default(cuid())
  phoneNumber          String           @unique
  phoneNumberId        String
  wabaId               String
  encryptedAccessToken String
  displayName          String?
  status               NumberPoolStatus @default(AVAILABLE)
  assignedTo           String?
  registeredAt         DateTime?
  createdAt            DateTime         @default(now())
}

model Template {
  id             String         @id @default(cuid())
  workspaceId    String
  metaTemplateId String?
  name           String
  category       String
  language       String
  components     Json
  status         TemplateStatus @default(PENDING)
  aiGenerated    Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now()) @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns Campaign[]
}

enum TemplateStatus {
  PENDING
  APPROVED
  REJECTED
}

model Contact {
  id                 String              @id @default(cuid())
  workspaceId        String
  name               String
  phoneNumber        String
  email              String?
  tags               String[]
  optedOut           Boolean             @default(false)
  createdAt          DateTime            @default(now())
  campaignRecipients CampaignRecipient[]
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations      Conversation[]
  segments           Segment[]           @relation("ContactSegments")
}

model Campaign {
  id            String              @id @default(cuid())
  workspaceId   String
  name          String
  templateId    String
  waNumberId    String?
  status        CampaignStatus      @default(DRAFT)
  totalContacts Int                 @default(0)
  sent          Int                 @default(0)
  delivered     Int                 @default(0)
  read          Int                 @default(0)
  failed        Int                 @default(0)
  scheduledAt   DateTime?
  launchedAt    DateTime?
  completedAt   DateTime?
  aiGenerated   Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt

  workspace  Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  template   Template            @relation(fields: [templateId], references: [id])
  waNumber   WaNumber?           @relation(fields: [waNumberId], references: [id], onDelete: SetNull)
  recipients CampaignRecipient[]
}

enum CampaignStatus {
  DRAFT
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model CampaignRecipient {
  id          String                  @id @default(cuid())
  campaignId  String
  contactId   String
  status      CampaignRecipientStatus @default(PENDING)
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  failedAt    DateTime?
  failReason  String?
  campaign    Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact     Contact                 @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Conversation {
  id            String             @id @default(cuid())
  workspaceId   String
  contactId     String
  waNumberId    String
  status        ConversationStatus @default(OPEN)
  unreadCount   Int                @default(0)
  label         String?
  lastMessageAt DateTime           @default(now())
  createdAt     DateTime           @default(now())
  contact       Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  waNumber      WaNumber           @relation(fields: [waNumberId], references: [id])
  workspace     Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages      Message[]
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  body           String
  direction      MessageDirection
  metaMessageId  String?
  senderUserId   String?
  sentAt         DateTime         @default(now())
  createdAt      DateTime         @default(now())
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser     User?            @relation(fields: [senderUserId], references: [id])
}

model AutomationTrigger {
  id               String    @id @default(cuid())
  workspaceId      String
  keyword          String
  responseTemplate String
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Workflow {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  isActive    Boolean   @default(true)
  nodes       Json      // List of visual nodes
  edges       Json      // Connections between nodes
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  keyHash     String
  keyPrefix   String
  environment String    @default("production")
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Invoice {
  id          String    @id @default(cuid())
  workspaceId String
  invoiceDate DateTime
  amount      Float
  currency    String    @default("USD")
  status      String    @default("PAID")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  CLIENT
}

enum NumberPoolStatus {
  AVAILABLE
  ASSIGNED
  BANNED
}

enum CampaignRecipientStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum ConversationStatus {
  OPEN
  RESOLVED
  PENDING
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model AiSession {
  id          String   @id @default(cuid())
  userId      String?
  workspaceId String?
  state       Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Segment {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  desc        String?
  color       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts    Contact[] @relation("ContactSegments")
}

model WhatsappForm {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  submissions Int       @default(0)
  fields      Int       @default(1)
  status      String    @default("Draft")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
