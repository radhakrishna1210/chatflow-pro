generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  passwordHash     String?
  googleId         String?           @unique
  createdAt        DateTime          @default(now())
  messages         Message[]
  refreshTokens    RefreshToken[]
  workspaceMembers WorkspaceMember[]
}

model Workspace {
  id                           String              @id @default(cuid())
  name                         String
  plan                         String              @default("FREE")
  webhookUrl                   String?
  webhookVerifyToken           String              @default("")
  notifyNewConversation        Boolean             @default(true)
  notifyTemplateApproved       Boolean             @default(true)
  notifyTemplateRejected       Boolean             @default(true)
  notifyCampaignCompleted      Boolean             @default(true)
  notifyHighOptout             Boolean             @default(true)
  notifyRateLimit              Boolean             @default(true)
  emailNotifyCampaignCompleted Boolean             @default(true)
  emailNotifyMemberInvite      Boolean             @default(true)
  emailNotifyTemplateApproved  Boolean             @default(true)
  emailNotifyTemplateRejected  Boolean             @default(true)
  autoOooEnabled               Boolean             @default(true)
  autoWelcomeEnabled           Boolean             @default(true)
  autoDelayedEnabled           Boolean             @default(false)
  voiceAiEnabled               Boolean             @default(false)
  voiceAiName                  String              @default("MyCallGenie")
  voiceAiPrompt                String              @default("Greet the caller and ask for their details.")
  voiceAiPhone                 String              @default("")
  aiAgentEnabled               Boolean             @default(false)
  aiAgentName                  String              @default("Assistant")
  aiAgentPrompt                String              @default("You are a helpful customer support agent. Answer briefly and politely.")
  aiAgentKnowledge             String              @default("")
  aiAgentModel                 String              @default("gemini-1.5-flash")
  aiAgentDeployedAt            DateTime?
  intentMatchingEnabled        Boolean             @default(false)
  intentMatchThreshold         Float               @default(0.6)
  suspended                    Boolean             @default(false)
  suspendedReason              String?
  walletBalance                Decimal             @default(0) @db.Decimal(12, 2)
  createdAt                    DateTime            @default(now())
  apiKeys                      ApiKey[]
  triggers                     AutomationTrigger[]
  campaigns                    Campaign[]
  contacts                     Contact[]
  conversations                Conversation[]
  invoices                     Invoice[]
  templates                    Template[]
  waNumbers                    WaNumber[]
  members                      WorkspaceMember[]
  workflows                    Workflow[]
  segments                     Segment[]
  whatsappForms                WhatsappForm[]
  walletTransactions           WalletTransaction[]
  integrations                 WorkspaceIntegration[]
  supportTickets               SupportTicket[]
  subscription                 Subscription?
  usageCounters                UsageCounter[]
}

model WorkspaceMember {
  userId      String
  workspaceId String
  role        Role      @default(CLIENT)
  joinedAt    DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([userId, workspaceId])
}

model WaNumber {
  id                   String         @id @default(cuid())
  workspaceId          String
  phoneNumber          String
  metaPhoneNumberId    String
  wabaId               String
  encryptedAccessToken String
  displayName          String?
  quality              String?
  status               String         @default("ACTIVE")
  messagingLimit       String?
  appSubscribed        Boolean        @default(false)
  createdAt            DateTime       @default(now())
  campaigns            Campaign[]
  conversations        Conversation[]
  templates            Template[]
  workspace            Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model NumberPool {
  id                   String           @id @default(cuid())
  phoneNumber          String           @unique
  phoneNumberId        String?
  wabaId               String?
  encryptedAccessToken String?
  displayName          String?
  status               NumberPoolStatus @default(AVAILABLE)
  assignedTo           String?
  registeredAt         DateTime?
  createdAt            DateTime         @default(now())
  provider             String           @default("META")
  twilioSid            String?
}

model Template {
  id             String         @id @default(cuid())
  workspaceId    String
  waNumberId     String?
  metaTemplateId String?
  name           String
  category       String
  language       String
  components     Json
  status         TemplateStatus @default(PENDING)
  aiGenerated    Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now()) @updatedAt
  campaigns      Campaign[]
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  waNumber       WaNumber?      @relation(fields: [waNumberId], references: [id], onDelete: Cascade)
}

model Contact {
  id                 String              @id @default(cuid())
  workspaceId        String
  name               String
  phoneNumber        String
  email              String?
  tags               String[]
  optedOut           Boolean             @default(false)
  createdAt          DateTime            @default(now())
  campaignRecipients CampaignRecipient[]
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations      Conversation[]
  segments           Segment[]           @relation("ContactSegments")

  @@unique([workspaceId, phoneNumber])
}

model Campaign {
  id            String              @id @default(cuid())
  workspaceId   String
  name          String
  templateId    String
  waNumberId    String?
  status        CampaignStatus      @default(DRAFT)
  totalContacts Int                 @default(0)
  sent          Int                 @default(0)
  delivered     Int                 @default(0)
  read          Int                 @default(0)
  failed        Int                 @default(0)
  scheduledAt   DateTime?
  launchedAt    DateTime?
  completedAt   DateTime?
  aiGenerated   Boolean             @default(false)
  queueJobId    String?
  replyRules    Json?
  retryConfig   Json?
  trackingConfig Json?
  fallbackConfig Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @default(now()) @updatedAt
  template      Template            @relation(fields: [templateId], references: [id])
  waNumber      WaNumber?           @relation(fields: [waNumberId], references: [id], onDelete: SetNull)
  workspace     Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recipients    CampaignRecipient[]
}

model CampaignRecipient {
  id          String                  @id @default(cuid())
  campaignId  String
  contactId   String
  status      CampaignRecipientStatus @default(PENDING)
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  failedAt    DateTime?
  failReason  String?
  campaign    Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact     Contact                 @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@unique([campaignId, contactId])
}

model Conversation {
  id            String             @id @default(cuid())
  workspaceId   String
  contactId     String
  waNumberId    String
  status        ConversationStatus @default(OPEN)
  unreadCount   Int                @default(0)
  label         String?
  lastMessageAt DateTime           @default(now())
  createdAt     DateTime           @default(now())
  contact       Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  waNumber      WaNumber           @relation(fields: [waNumberId], references: [id])
  workspace     Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages      Message[]
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  body           String
  direction      MessageDirection
  metaMessageId  String?
  senderUserId   String?
  campaignRecipientId String?
  sentAt         DateTime         @default(now())
  createdAt      DateTime         @default(now())
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser     User?            @relation(fields: [senderUserId], references: [id])
  campaignRecipient   CampaignRecipient? @relation(fields: [campaignRecipientId], references: [id], onDelete: SetNull)

  @@index([metaMessageId])
}

model AutomationTrigger {
  id               String    @id @default(cuid())
  workspaceId      String
  keyword          String
  responseTemplate String
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Workflow {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  isActive    Boolean   @default(true)
  nodes       Json
  edges       Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  keyHash     String
  keyPrefix   String
  environment String    @default("production")
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Invoice {
  id          String    @id @default(cuid())
  workspaceId String
  invoiceDate DateTime
  description String?
  amount      Float
  currency    String    @default("USD")
  status      String    @default("PAID")
  reference   String?   // gateway payment id, for reconciliation
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  CLIENT
}

enum NumberPoolStatus {
  AVAILABLE
  ASSIGNED
  BANNED
  PROVISIONING
}

enum TemplateStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum CampaignRecipientStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum ConversationStatus {
  OPEN
  RESOLVED
  PENDING
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model AiSession {
  id          String   @id @default(cuid())
  userId      String?
  workspaceId String?
  state       Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Segment {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  desc        String?
  color       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts    Contact[] @relation("ContactSegments")
}

model WhatsappForm {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  submissions Int       @default(0)
  fields      Int       @default(1)
  status      String    @default("Draft")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}


model WalletTransaction {
  id          String    @id @default(cuid())
  workspaceId String
  amount      Decimal   @db.Decimal(12, 2)
  type        String    // CREDIT | DEBIT
  reason      String
  balanceAfter Decimal  @db.Decimal(12, 2)
  reference   String?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

model WorkspaceIntegration {
  id                   String    @id @default(cuid())
  workspaceId          String
  provider             String
  type                 String    // apikey | oauth | webhook
  status               String    @default("CONNECTED")
  encryptedCredentials String?
  config               Json?
  connectedAt          DateTime  @default(now())
  updatedAt            DateTime  @default(now()) @updatedAt
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
}

model EmailOtp {
  id             String   @id @default(cuid())
  email          String
  codeHash       String
  purpose        String   @default("SIGNUP")
  name           String?
  passwordHash   String?
  attempts       Int      @default(0)
  consumed       Boolean  @default(false)
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  @@index([email, purpose])
}

model Plan {
  id                String         @id @default(cuid())
  key               String         @unique // "FREE" | "STARTER" | "PRO" | "ENTERPRISE" | ...
  name              String
  priceMonthly      Decimal        @db.Decimal(10, 2)
  currency          String         @default("USD")
  messageQuota      Int            // included messages per billing cycle; 0 = none, -1 = unlimited
  contactLimit      Int?           // null = unlimited
  memberLimit       Int?
  campaignLimit     Int?
  apiKeyLimit       Int?
  overageRatePerMsg Decimal        @db.Decimal(10, 4)
  features          Json           @default("{}")
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  subscriptions     Subscription[] @relation("SubscriptionPlan")
  pendingFor        Subscription[] @relation("SubscriptionPendingPlan")
}

model Subscription {
  id                 String    @id @default(cuid())
  workspaceId        String    @unique
  planId             String
  pendingPlanId      String?   // scheduled upgrade/downgrade — applied at the next cycle rollover (§12.6/§12.8: no proration)
  status             String    @default("ACTIVE") // ACTIVE | PAST_DUE | CANCELLED | EXPIRED
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan               Plan      @relation("SubscriptionPlan", fields: [planId], references: [id])
  pendingPlan        Plan?     @relation("SubscriptionPendingPlan", fields: [pendingPlanId], references: [id])
}

model UsageCounter {
  id           String   @id @default(cuid())
  workspaceId  String
  periodStart  DateTime
  periodEnd    DateTime
  messagesUsed Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, periodStart])
}

model SupportTicket {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String?
  subject     String
  message     String
  category    String    @default("GENERAL")
  status      String    @default("OPEN")
  adminNote   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}
