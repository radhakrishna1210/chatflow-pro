# App
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
CHATFLOW_PRO_URL=http://localhost:8080
JSON_BODY_LIMIT=2mb

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/chatflowpro

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-32-char-minimum-access-secret!!
JWT_REFRESH_SECRET=your-32-char-minimum-refresh-secret!
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Encryption (exactly 32 UTF-8 chars = 32-byte AES-256 key)
ENCRYPTION_KEY=your-exactly-32-character-key-here

# Meta / WhatsApp Cloud API
META_APP_ID=your_facebook_app_id
META_APP_SECRET=your_facebook_app_secret
META_BUSINESS_ID=your_meta_business_id
META_WABA_ID=your_default_waba_id
META_SYSTEM_USER_ID=your_system_user_id
META_DISPLAY_NAME=YourBrandName
META_SYSTEM_USER_TOKEN=your_system_user_long_lived_token
META_API_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=your_random_webhook_verify_token

# Twilio (optional)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Campaign worker
CAMPAIGN_BATCH_SIZE=50
CAMPAIGN_WORKER_CONCURRENCY=2

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_CALLBACK_URL is auto-derived as http://localhost:PORT/api/v1/auth/google/callback
# Set explicitly to override (e.g. in production):
# GOOGLE_CALLBACK_URL=https://yourdomain.com/api/v1/auth/google/callback
